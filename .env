# =====================================================
# MANGO MARKET PLATFORM - ENVIRONMENT VARIABLES
# =====================================================
# NEVER commit .env with sensitive data to version control!
# Copy settings from .env.example and fill in with actual values

# =====================================================
# FLASK CONFIGURATION
# =====================================================
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# SECRET_KEY: Used for session management and CSRF protection
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REQUIRED: Must be set in production!
SECRET_KEY=mango_market_secure_key_2026

# =====================================================
# DATABASE CONFIGURATION (MySQL)
